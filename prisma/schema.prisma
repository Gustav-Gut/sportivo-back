// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  address       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  active        Boolean        @default(true)
  users         User[]
  plans         Plan[]
  subscriptions Subscription[]
  payments      Payment[]
  sports        SchoolSport[]
  classes       Class[]
  facilities    Facility[]
}

model User {
  id               String          @id @default(uuid())
  rut              String
  firstName        String
  lastName         String
  email            String
  phone            String?
  password         String
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  schoolId         String
  role             Role            @default(ADMIN)
  // Relaciones 1-a-1 a los perfiles
  studentProfile   StudentProfile?
  tutorProfile     TutorProfile?
  coachProfile     CoachProfile?
  school           School          @relation(fields: [schoolId], references: [id])
  payments         Payment[]
  paidSubscriptions Subscription[] @relation("PayerSubscriptions")
  studentSubscription Subscription? @relation("StudentSubscriptions")
  tutorsRelation   UserTutor[]     @relation("StudentRelation")
  studentsRelation UserTutor[]     @relation("TutorRelation")

  // Relaciones de Clases y Asistencia (Coach y Student)
  coachedClasses    Class[]             @relation("CoachClass")
  enrollments       ClassEnrollment[]
  attendanceTaken   AttendanceSession[] @relation("SessionCoach")
  attendanceRecords AttendanceRecord[]

  @@unique([rut, schoolId])
  @@unique([email, schoolId])
}

model UserTutor {
  id           String @id @default(uuid())
  tutorId      String
  studentId    String
  relationType String
  tutor        User   @relation("TutorRelation", fields: [tutorId], references: [id])
  student      User   @relation("StudentRelation", fields: [studentId], references: [id])

  @@unique([tutorId, studentId])
}

model Plan {
  id             String         @id @default(uuid())
  name           String
  description    String
  price          Float
  durationMonths Int            @default(1)
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  schoolId       String
  subscriptions  Subscription[]
  school         School         @relation(fields: [schoolId], references: [id])

  @@unique([name, schoolId])
}

model Subscription {
  id         String             @id @default(uuid())
  planId     String
  provider   PaymentProvider
  externalId String?
  startDate  DateTime           @default(now())
  endDate    DateTime?
  
  payerId    String
  studentId  String             @unique // El estudiante (beneficiario) solo puede tener 1 suscripción activa

  schoolId   String
  status     SubscriptionStatus @default(PENDING)
  school     School             @relation(fields: [schoolId], references: [id])
  payer      User               @relation("PayerSubscriptions", fields: [payerId], references: [id])
  student    User               @relation("StudentSubscriptions", fields: [studentId], references: [id])
  plan       Plan               @relation(fields: [planId], references: [id])
}

model Payment {
  id         String          @id @default(uuid())
  amount     Float
  currency   String          @default("CLP")
  provider   PaymentProvider
  externalId String?
  status     PaymentStatus   @default(PENDING)
  createdAt  DateTime        @default(now())
  userId     String
  schoolId   String
  school     School          @relation(fields: [schoolId], references: [id])
  user       User            @relation(fields: [userId], references: [id])
}

enum Role {
  SUPERADMIN
  ADMIN
  COACH
  TUTOR
  STUDENT
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentProvider {
  MERCADOPAGO
  TOKU
  PAYPAL
  STRIPE
}

model StudentProfile {
  id     String @id @default(uuid())
  userId String @unique // Clave para la relación 1 a 1
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Campos Físicos / Biológicos
  birthDate    DateTime?
  weight       Float? // en kg
  height       Float? // en cm
  bloodType    String? // ej: 'O+', 'A-'
  medicalNotes String? // Alergias, asma, lesiones previas

  // Campos deportivos dinámicos (Custom Fields)
  sportData Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sport {
  id   String @id @default(uuid())
  name String @unique // Ej: "Fútbol", "Básquetbol"

  // La plantilla base de cómo se ve la ficha deportiva
  // Ej: [{"key": "position", "label": "Posición", "type": "select", "options": ["Portero", "Defensa"]}]
  defaultFields Json

  schools SchoolSport[]
  classes Class[]
}

model SchoolSport {
  id       String @id @default(uuid())
  schoolId String
  sportId  String

  school School @relation(fields: [schoolId], references: [id])
  sport  Sport  @relation(fields: [sportId], references: [id])

  // Si la escuela quiere agregar campos extra o cambiar los tuyos, se guarda aquí.
  // Si está vacío, tu Frontend usa los 'defaultFields' del Sport.
  customFields Json?

  @@unique([schoolId, sportId])
}

model TutorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Información de contacto en caso de emergencia si se requiere algo extra
  emergencyContact String? // Un número secundario
  address          String?
  occupation       String? // A veces útil para patrocinios o conocer a la comunidad

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoachProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Resumen profesional
  bio             String? // Pequeña descripción
  specialty       String? // Ej: "Preparador Físico", "Técnico Táctico"
  yearsExperience Int?

  // Títulos o certificaciones
  certifications String? // Ej: "Licencia PRO INAF"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------
// MÓDULO CLASES (GROUPS) Y ASISTENCIA (ATTENDANCE)
// ----------------------------------------------------

model Class {
  id   String @id @default(uuid())
  name String // Ej: "Sub-12 Martes/Jueves"

  schoolId String
  sportId  String
  coachId  String? // El profesor a cargo

  schedule    String? // Ej: "Lunes 18:00 - 20:00" (Legacy)
  dayOfWeek   Int?    // 0 = Domingo, 1 = Lunes, etc.
  startTime   DateTime?
  endTime     DateTime?
  maxStudents Int? // Límite de cupos dinámico por clase
  active      Boolean @default(true)

  school School @relation(fields: [schoolId], references: [id])
  sport  Sport  @relation(fields: [sportId], references: [id])
  coach  User?  @relation("CoachClass", fields: [coachId], references: [id])
  
  facilityId String?
  facility   Facility? @relation(fields: [facilityId], references: [id])

  enrollments ClassEnrollment[]
  sessions    AttendanceSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClassEnrollment {
  id        String @id @default(uuid())
  classId   String
  studentId String

  enrolledAt DateTime @default(now())

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId]) // Un alumno no puede inscribirse dos veces en la misma clase
}

model AttendanceSession {
  id      String   @id @default(uuid())
  classId String
  coachId String // Quién tomó la lista
  date    DateTime @default(now()) // La fecha de la clase dictada

  class   Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  coach   User               @relation("SessionCoach", fields: [coachId], references: [id])
  records AttendanceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AttendanceRecord {
  id        String @id @default(uuid())
  sessionId String
  studentId String

  status AttendanceStatus @default(PRESENT)
  notes  String? // Justificaciones ("Llegó enfermo", "Permiso del doctor")

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId]) // Un registro por alumno, por sesión
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model Facility {
  id        String   @id @default(uuid())
  name      String   // Ej: "Cancha de Pasto 1", "Gimnasio Techado"
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  classes   Class[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
