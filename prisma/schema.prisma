// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id              String         @id @default(uuid())
  name            String
  slug            String         @unique
  address         String?
  email           String?
  phone           String?
  website         String?
  logoUrl         String?
  description     String?
  active          Boolean        @default(true)
  users           User[]
  plans           Plan[]
  subscriptions   Subscription[]
  payments        Payment[]
  sports          SchoolSport[]
  lessons         Lesson[]
  facilities      Facility[]
  moraAlertDays   Int            @default(5)
  preDueAlertDays Int            @default(3)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  notificationTemplates NotificationTemplate[]
}

model User {
  id                  String              @id @default(uuid())
  rut                 String
  firstName           String
  lastName            String
  email               String
  phone               String?
  password            String
  active              Boolean             @default(true)
  schoolId            String
  roles               Role[]              @default([STUDENT])
  studentProfile      StudentProfile?
  tutorProfile        TutorProfile?
  coachProfile        CoachProfile?
  payments            Payment[]
  enrollments         LessonEnrollment[]
  attendanceRecords   AttendanceRecord[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  school              School              @relation(fields: [schoolId], references: [id])
  paidSubscriptions   Subscription[]      @relation("PayerSubscriptions")
  studentSubscription Subscription[]      @relation("StudentSubscriptions")
  tutorsRelation      UserTutor[]         @relation("StudentRelation")
  studentsRelation    UserTutor[]         @relation("TutorRelation")
  coachedLessons      Lesson[]            @relation("CoachLesson")
  attendanceTaken     AttendanceSession[] @relation("SessionCoach")

  @@unique([rut, schoolId])
  @@unique([email, schoolId])
}

model UserTutor {
  id           String @id @default(uuid())
  tutorId      String
  studentId    String
  relationType String
  tutor        User   @relation("TutorRelation", fields: [tutorId], references: [id])
  student      User   @relation("StudentRelation", fields: [studentId], references: [id])

  @@unique([tutorId, studentId])
}

model Plan {
  id             String         @id @default(uuid())
  name           String
  description    String
  price          Float
  durationMonths Int            @default(1)
  active         Boolean        @default(true)
  schoolId       String
  subscriptions  Subscription[]
  createdAt      DateTime       @default(now())
  school         School         @relation(fields: [schoolId], references: [id])

  @@unique([name, schoolId])
}

model Subscription {
  id         String             @id @default(uuid())
  planId     String
  externalId String?
  startDate  DateTime           @default(now())
  endDate    DateTime?
  payerId    String
  studentId  String
  schoolId   String
  provider   PaymentProvider
  status     SubscriptionStatus @default(PENDING)
  payments   Payment[]
  school     School             @relation(fields: [schoolId], references: [id])
  payer      User               @relation("PayerSubscriptions", fields: [payerId], references: [id])
  student    User               @relation("StudentSubscriptions", fields: [studentId], references: [id])
  plan       Plan               @relation(fields: [planId], references: [id])
}

model Payment {
  id              String          @id @default(uuid())
  amount          Float
  currency        String          @default("CLP")
  externalId      String?
  payerId         String
  schoolId        String
  provider        PaymentProvider
  status          PaymentStatus   @default(PENDING)
  dueDate         DateTime?
  paidAt          DateTime?
  lastAlertSentAt DateTime?
  subscriptionId  String
  subscription    Subscription    @relation(fields: [subscriptionId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  school          School          @relation(fields: [schoolId], references: [id])
  payer           User            @relation(fields: [payerId], references: [id])
}

model StudentProfile {
  id           String    @id @default(uuid())
  userId       String    @unique
  birthDate    DateTime?
  weight       Float?
  height       Float?
  bloodType    String?
  medicalNotes String?
  sportData    Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Sport {
  id            String        @id @default(uuid())
  name          String        @unique
  defaultFields Json
  schools       SchoolSport[]
}

model SchoolSport {
  id           String  @id @default(uuid())
  schoolId     String
  sportId      String
  customFields Json?
  active       Boolean @default(true)
  school       School  @relation(fields: [schoolId], references: [id])
  sport        Sport   @relation(fields: [sportId], references: [id])
  lessons      Lesson[]

  @@unique([schoolId, sportId])
}

model TutorProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  emergencyContact String?
  address          String?
  occupation       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  bio             String?
  specialty       String?
  yearsExperience Int?
  certifications  String?
  sportData       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lesson {
  id            String              @id @default(uuid())
  name          String
  schoolId      String
  schoolSportId String
  coachId       String
  dayOfWeek     DayOfWeek
  startTime     String
  endTime       String
  maxStudents   Int
  active        Boolean             @default(true)
  facilityId    String
  enrollments   LessonEnrollment[]
  sessions      AttendanceSession[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  school        School              @relation(fields: [schoolId], references: [id])
  schoolSport   SchoolSport         @relation(fields: [schoolSportId], references: [id])
  coach         User                @relation("CoachLesson", fields: [coachId], references: [id])
  facility      Facility            @relation(fields: [facilityId], references: [id])
}

model Facility {
  id        String   @id @default(uuid())
  name      String
  schoolId  String
  lessons   Lesson[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
}

model LessonEnrollment {
  id         String   @id @default(uuid())
  lessonId   String
  studentId  String
  enrolledAt DateTime @default(now())
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lessonId, studentId])
}

model AttendanceSession {
  id        String             @id @default(uuid())
  lessonId  String
  coachId   String
  date      DateTime           @default(now())
  records   AttendanceRecord[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  lesson    Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  coach     User               @relation("SessionCoach", fields: [coachId], references: [id])
}

model AttendanceRecord {
  id        String            @id @default(uuid())
  sessionId String
  studentId String
  notes     String?
  status    AttendanceStatus  @default(PRESENT)
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}

enum Role {
  SUPERADMIN
  ADMIN
  COACH
  TUTOR
  STUDENT
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentProvider {
  MERCADOPAGO
  TOKU
  PAYPAL
  STRIPE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum NotificationType {
  PRE_DUE
  MORA
  MANUAL_LINK
}

model NotificationTemplate {
  id        String              @id @default(uuid())
  schoolId  String
  type      NotificationType
  channel   NotificationChannel
  subject   String?
  body      String              @db.Text
  active    Boolean             @default(true)
  school    School              @relation(fields: [schoolId], references: [id])
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([schoolId, type, channel])
}
