// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  address       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  active        Boolean        @default(true)
  users         User[]
  plans         Plan[]
  subscriptions Subscription[]
  payments      Payment[]
}

model User {
  id               String        @id @default(uuid())
  rut              String
  firstName        String
  lastName         String
  email            String
  phone            String?
  password         String
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  schoolId         String
  role             Role          @default(ADMIN)
  school           School        @relation(fields: [schoolId], references: [id])
  payments         Payment[]
  subscription     Subscription?
  tutorsRelation   UserTutor[]   @relation("StudentRelation")
  studentsRelation UserTutor[]   @relation("TutorRelation")

  @@unique([rut, schoolId])
  @@unique([email, schoolId])
}

model UserTutor {
  id           String @id @default(uuid())
  tutorId      String
  studentId    String
  relationType String
  tutor        User   @relation("TutorRelation", fields: [tutorId], references: [id])
  student      User   @relation("StudentRelation", fields: [studentId], references: [id])

  @@unique([tutorId, studentId])
}

model Plan {
  id             String         @id @default(uuid())
  name           String
  description    String
  price          Float
  durationMonths Int            @default(1)
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  schoolId       String
  subscriptions  Subscription[]
  school         School         @relation(fields: [schoolId], references: [id])

  @@unique([name, schoolId])
}

model Subscription {
  id         String             @id @default(uuid())
  planId     String
  provider   PaymentProvider
  externalId String?
  startDate  DateTime           @default(now())
  endDate    DateTime?
  userId     String             @unique
  schoolId   String
  status     SubscriptionStatus @default(PENDING)
  school     School             @relation(fields: [schoolId], references: [id])
  user       User               @relation(fields: [userId], references: [id])
  plan       Plan               @relation(fields: [planId], references: [id])
}

model Payment {
  id         String          @id @default(uuid())
  amount     Float
  currency   String          @default("CLP")
  provider   PaymentProvider
  externalId String?
  status     PaymentStatus   @default(PENDING)
  createdAt  DateTime        @default(now())
  userId     String
  schoolId   String
  school     School          @relation(fields: [schoolId], references: [id])
  user       User            @relation(fields: [userId], references: [id])
}

enum Role {
  SUPERADMIN
  ADMIN
  COACH
  TUTOR
  STUDENT
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentProvider {
  MERCADOPAGO
  TOKU
  PAYPAL
  STRIPE
}
